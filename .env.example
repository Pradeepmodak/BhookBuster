# =========================================================================
# BHOOKBUSTER - SYSTEM ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================
# Duplicate this file as '.env' in appropriate service directories, or use
# a central configuration loader.
#

# -------------------------------------------------------------------------
# DATABASE & DATA STACK
# -------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/bhookbuster?retryWrites=true&w=majority
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672

# -------------------------------------------------------------------------
# JWT & SECURITY
# -------------------------------------------------------------------------
JWT_SECRET_KEY=generate-a-strong-random-32-byte-hex-string
CORS_ORIGIN=http://localhost:5173

# -------------------------------------------------------------------------
# THIRD PARTY INTEGRATIONS
# -------------------------------------------------------------------------
# Cloudinary Configuration
CLOUD_NAME=your-cloudinary-cloud-name
CLOUD_API_KEY=your-cloudinary-api-key
CLOUD_API_SECRET=your-cloudinary-api-secret

# Payments Integration
STRIPE_SECRET_KEY=sk_test_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret

# -------------------------------------------------------------------------
# AI GATEWAY & GOOGLE GEMINI
# -------------------------------------------------------------------------
# Google Gemini API Key (Obtained from Google AI Studio: aistudio.google.com)
GOOGLE_AI_API_KEY=AIzaSy...

# Secure Microservice HMAC Secret
# Generated locally using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_HMAC_SECRET=generate-a-64-character-hex-secret-for-microservice-auth

# Internal AI Gateway Microservice Address
AI_GATEWAY_URL=http://localhost:5010

# -------------------------------------------------------------------------
# SERVICE PORT BINDINGS
# -------------------------------------------------------------------------
AUTH_PORT=5000
RESTAURANT_PORT=3000
RIDER_PORT=4000
UTILS_PORT=7000
ADMIN_PORT=6000
REALTIME_PORT=8000
AI_GATEWAY_PORT=5010
